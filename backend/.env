# Ambiente (development, production, testing)
# Environment (development, production, testing)

# Configurações da API
# API Settings
API_V1_STR=/api/v1
PROJECT_NAME=Licitação Hub API

# Segurança
# Security
SECRET_KEY=supersecretkey_CHANGE_THIS_VALUE_IN_PRODUCTION!
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=11520  # 8 days

# CORS
# Origens permitidas para CORS (separadas por vírgula)
# Allowed origins for CORS (comma-separated)
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Banco de Dados PostgreSQL
# PostgreSQL Database
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=licitacao_hub
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/licitacao_hub
#            [protocolo/driver]://[usuário:senha]@[host]:[porta]/[nome do banco]
# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# Serviço LLM
# LLM Service
LLM_PROVIDER=openai  # openai, gemini
LLM_API_KEY=your-api-key-here
LLM_MODEL=gpt-4o

# Usuário Admin Inicial
# Initial Admin User
FIRST_SUPERUSER_EMAIL=admin@example.com
FIRST_SUPERUSER_PASSWORD=admin_password_change_me

# Upload de Arquivos
# File Uploads
UPLOAD_DIRECTORY=/app/uploads
# MAX_UPLOAD_SIZE=10485760  # 10MB - Commented out as it's not configured in Settings model


# Correto:
#DATABASE_URL=postgresql://user:password@db:5432/dbname