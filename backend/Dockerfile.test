# filepath: Dockerfile

# Use an official Python runtime as a parent image
FROM python:3.9-slim

# Adicione estas linhas antes do RUN poetry install
ENV POETRY_VIRTUALENVS_IN_PROJECT=true
ENV POETRY_CACHE_DIR=/tmp/poetry_cache
RUN mkdir -p /app/.venv && chmod -R 777 /app/.venv

# Set the working directory in the container
WORKDIR /app

# Install Poetry
RUN pip install poetry

# Copy project files
COPY pyproject.toml poetry.lock* ./

# Install dependencies (including dev dependencies)
# Use --no-root if you install project code later via COPY . .
# Omit --only dev if pytest is a main dependency, or install all groups needed for tests
RUN poetry install --no-interaction --no-ansi

# Copy the rest of the application code
COPY . .

# Command to run tests (adjust as needed)
CMD ["poetry", "run", "pytest"]