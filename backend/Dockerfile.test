# Multi-stage build for test environment
FROM python:3.12.3-slim AS builder

# Create poetry cache directory with proper permissions
RUN mkdir -p /tmp/poetry_cache && chmod 777 /tmp/poetry_cache

# Install Poetry
RUN pip install "poetry==1.7.1"

# Set up poetry configuration
WORKDIR /app
COPY pyproject.toml poetry.lock* /app/

# Install dependencies INCLUDING DEV DEPENDENCIES for testing
RUN poetry config virtualenvs.create false && \
    poetry install --no-interaction --no-ansi

# Final stage
FROM python:3.12.3-slim

# Create app user
RUN addgroup --system app && \
    adduser --system --group app

WORKDIR /app

# Install PostgreSQL client for database checks
RUN apt-get update && apt-get install -y postgresql-client && rm -rf /var/lib/apt/lists/*

# Create uploads directory
RUN mkdir -p /app/uploads && \
    chown -R app:app /app/uploads

# Copy dependencies from builder stage
COPY --from=builder /usr/local/lib/python3.12/site-packages /usr/local/lib/python3.12/site-packages
COPY --from=builder /usr/local/bin /usr/local/bin

# Copy the entrypoint script
COPY test-entrypoint.sh /app/test-entrypoint.sh
RUN chmod +x /app/test-entrypoint.sh

# Copy application code
COPY --chown=app:app ./app /app/app
COPY --chown=app:app ./alembic /app/alembic
COPY --chown=app:app ./alembic.ini /app/
COPY --chown=app:app ./tests /app/tests

# Create poetry cache directory
# DO NOT try to remove it - this will be a volume mount
RUN mkdir -p /tmp/poetry_cache && chmod 777 /tmp/poetry_cache

# Switch to non-root user for better security
USER app

# IMPORTANT: DO NOT try to remove /tmp/poetry_cache here
# as it will be a mounted volume in docker-compose

ENTRYPOINT ["/app/test-entrypoint.sh"]
CMD ["python", "-m", "pytest", "tests/"]